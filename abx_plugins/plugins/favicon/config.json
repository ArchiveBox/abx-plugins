{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Favicon",
  "description": "Fetch and save the site favicon or touch icon.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [],
  "output_mimetypes": [
    "image/"
  ],
  "properties": {
    "FAVICON_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_FAVICON",
        "USE_FAVICON"
      ],
      "description": "Enable favicon downloading"
    },
    "FAVICON_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for favicon fetch in seconds"
    },
    "FAVICON_USER_AGENT": {
      "type": "string",
      "default": "",
      "x-fallback": "USER_AGENT",
      "description": "User agent string"
    },
    "FAVICON_PROVIDER": {
      "type": "string",
      "default": "https://www.google.com/s2/favicons?domain={}&format=ico",
      "description": "Fallback favicon provider URL template. Supports either {} or {domain} placeholders."
    }
  }
}
