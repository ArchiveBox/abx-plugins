{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parse RSS URLs",
  "description": "Parse RSS and Atom feeds and emit discovered entry URLs as JSONL snapshot records.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [
    {
      "name": "feedparser",
      "binproviders": "uv",
      "min_version": null,
      "postinstall_scripts": true,
      "overrides": {
        "uv": {
          "install_root": "{LIB_DIR}/uv/packages/parse_rss_urls",
          "install_args": [
            "feedparser"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [
    "application/x-ndjson"
  ],
  "properties": {
    "PARSE_RSS_URLS_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "USE_PARSE_RSS_URLS"
      ],
      "description": "Enable RSS/Atom feed URL parsing"
    }
  }
}
