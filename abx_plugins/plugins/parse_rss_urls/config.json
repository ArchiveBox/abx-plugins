{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parse RSS URLs",
  "description": "Parse RSS and Atom feeds and emit discovered entry URLs as JSONL snapshot records.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [],
  "output_mimetypes": ["application/x-ndjson"],
  "properties": {
    "PARSE_RSS_URLS_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": ["USE_PARSE_RSS_URLS"],
      "description": "Enable RSS/Atom feed URL parsing"
    }
  }
}
