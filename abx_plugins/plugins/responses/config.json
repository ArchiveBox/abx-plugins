{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Responses",
  "description": "Capture HTTP response metadata for requests made during page load.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer,playwright",
      "min_version": "149.0.0",
      "postinstall_scripts": true
    }
  ],
  "output_mimetypes": [
    "application/x-ndjson",
    "text/",
    "image/",
    "audio/",
    "video/",
    "application/",
    "font/"
  ],
  "properties": {
    "RESPONSES_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_RESPONSES",
        "USE_RESPONSES"
      ],
      "description": "Enable HTTP response capture"
    },
    "RESPONSES_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for response capture in seconds"
    }
  }
}
