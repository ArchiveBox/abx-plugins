{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DOM",
  "description": "Save the fully rendered DOM HTML from the live page.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer",
      "min_version": null,
      "overrides": {
        "puppeteer": {
          "install_args": [
            "chrome@stable"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [
    "text/html"
  ],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "x-aliases": [
        "CHROMIUM_BINARY"
      ],
      "description": "Path to Chromium, Chrome for Testing, or Chrome Canary binary"
    },
    "DOM_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_DOM",
        "USE_DOM"
      ],
      "description": "Enable DOM capture"
    },
    "DOM_TIMEOUT": {
      "type": "integer",
      "default": 60,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for DOM capture in seconds"
    }
  }
}
