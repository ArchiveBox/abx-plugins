{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LiteParse",
  "description": "Extract text and metadata from PDFs and documents using LiteParse (by LlamaIndex). Supports OCR via Tesseract.js.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [
    {
      "name": "{LITEPARSE_BINARY}",
      "binproviders": "env,npm",
      "min_version": null,
      "overrides": {
        "npm": {
          "install_args": [
            "@llamaindex/liteparse"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [
    "text/plain",
    "application/json"
  ],
  "properties": {
    "LITEPARSE_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_LITEPARSE",
        "USE_LITEPARSE"
      ],
      "description": "Enable LiteParse document extraction"
    },
    "LITEPARSE_BINARY": {
      "type": "string",
      "default": "lit",
      "description": "Path to lit binary"
    },
    "LITEPARSE_TIMEOUT": {
      "type": "integer",
      "default": 120,
      "minimum": 10,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for LiteParse extraction in seconds"
    },
    "LITEPARSE_ARGS": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "x-aliases": [
        "LITEPARSE_DEFAULT_ARGS"
      ],
      "description": "Default LiteParse arguments"
    },
    "LITEPARSE_ARGS_EXTRA": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "x-aliases": [
        "LITEPARSE_EXTRA_ARGS"
      ],
      "description": "Extra arguments to append to LiteParse command"
    }
  }
}
