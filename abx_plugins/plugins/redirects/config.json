{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Redirects",
  "description": "Capture the redirect chain encountered while loading the page.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer",
      "min_version": "149.0.0",
      "overrides": {
        "puppeteer": {
          "install_args": [
            "chrome@stable"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [
    "application/x-ndjson"
  ],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "description": "Path to a Chromium-family browser binary"
    },
    "REDIRECTS_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_REDIRECTS",
        "USE_REDIRECTS"
      ],
      "description": "Enable redirect chain capture"
    },
    "REDIRECTS_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for redirect capture in seconds"
    }
  }
}
