{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Base",
  "description": "Provide shared utilities, helpers, and test support used by other plugins.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [],
  "output_mimetypes": [],
  "properties": {
    "ABX_RUNTIME": {
      "type": "string",
      "default": "abx-dl",
      "description": "Current host runtime name, eg. abx-dl or archivebox",
      "x-scope": "crawl_execution"
    },
    "ABX_INSTALL_CACHE": {
      "type": "object",
      "default": {},
      "additionalProperties": {
        "type": "string"
      },
      "description": "Runtime-derived install preflight cache keyed by binary name",
      "x-scope": "crawl_execution"
    },
    "SNAP_DIR": {
      "type": "string",
      "default": "",
      "description": "Base snapshot directory for per-snapshot hook output",
      "x-scope": "crawl_execution"
    },
    "CRAWL_DIR": {
      "type": "string",
      "default": "",
      "description": "Base crawl directory for per-crawl hook output",
      "x-scope": "crawl_execution"
    },
    "DATA_DIR": {
      "type": "string",
      "default": "",
      "description": "ArchiveBox collection directory",
      "x-scope": "crawl_execution"
    },
    "ABXPKG_LIB_DIR": {
      "type": "string",
      "default": "",
      "description": "Shared tools and binary installation root",
      "x-scope": "crawl_execution"
    },
    "PERSONAS_DIR": {
      "type": "string",
      "default": "",
      "description": "Shared personas root",
      "x-scope": "crawl_execution"
    },
    "ACTIVE_PERSONA": {
      "type": "string",
      "default": "Default",
      "description": "Active browser persona name",
      "x-scope": "crawl_execution"
    },
    "EXTRA_CONTEXT": {
      "type": "string",
      "default": "",
      "description": "JSON object merged into emitted JSONL event records",
      "x-scope": "crawl_execution"
    },
    "TIMEOUT": {
      "type": "integer",
      "default": 60,
      "minimum": 0,
      "description": "Default timeout in seconds for hooks that support a TIMEOUT fallback"
    },
    "USER_AGENT": {
      "type": "string",
      "default": "Mozilla/5.0 (compatible; ArchiveBox/1.0)",
      "description": "Default user agent string for HTTP requests and browser automation"
    },
    "PATH": {
      "type": "string",
      "default": "",
      "description": "Executable search path",
      "x-scope": "crawl_execution"
    },
    "NODE_MODULES_DIR": {
      "type": "string",
      "default": "",
      "description": "Shared Node.js module resolution root",
      "x-scope": "crawl_execution"
    },
    "NODE_MODULE_DIR": {
      "type": "string",
      "default": "",
      "description": "Legacy alias for NODE_MODULES_DIR",
      "x-scope": "crawl_execution"
    },
    "NODE_PATH": {
      "type": "string",
      "default": "",
      "description": "Node.js module lookup path",
      "x-scope": "crawl_execution"
    },
    "NODE_V8_COVERAGE": {
      "type": "string",
      "default": "",
      "description": "Optional V8 coverage output directory for Node.js hooks",
      "x-scope": "crawl_execution"
    }
  }
}
