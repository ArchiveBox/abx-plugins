{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HTML to Text",
  "description": "Convert archived HTML from other extractors into plain text for indexing and analysis.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [],
  "output_mimetypes": [
    "text/plain"
  ],
  "properties": {
    "HTMLTOTEXT_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_HTMLTOTEXT",
        "USE_HTMLTOTEXT"
      ],
      "description": "Enable HTML to text conversion"
    },
    "HTMLTOTEXT_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for HTML to text conversion in seconds"
    }
  }
}
