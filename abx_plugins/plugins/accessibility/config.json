{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Accessibility",
  "description": "Capture the browser accessibility tree for the archived page.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    "chrome"
  ],
  "output_mimetypes": [
    "application/json"
  ],
  "properties": {
    "ACCESSIBILITY_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_ACCESSIBILITY",
        "USE_ACCESSIBILITY"
      ],
      "description": "Enable accessibility tree capture"
    },
    "ACCESSIBILITY_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for accessibility capture in seconds"
    }
  }
}
