{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "uBlock Origin Lite",
  "description": "Install the uBlock Origin Lite extension to block ads, trackers, and other page clutter during archiving.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer,playwright",
      "min_version": "149.0.0",
      "postinstall_scripts": true
    },
    {
      "name": "ublock",
      "binproviders": "chromewebstore",
      "min_version": null,
      "overrides": {
        "chromewebstore": {
          "install_args": [
            "ddkjiahejlhfcafbddmgiahcphecmpfh",
            "--name=ublock"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [],
  "properties": {
    "UBLOCK_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "USE_UBLOCK"
      ],
      "description": "Enable uBlock Origin Lite browser extension for ad blocking"
    }
  }
}
