{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Modal Closer",
  "description": "Automatically dismiss dialogs, cookie banners, and framework modals while the page is being archived.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer",
      "min_version": null,
      "overrides": {
        "puppeteer": {
          "install_args": [
            "chromium@latest",
            "--install-deps"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "x-aliases": [
        "CHROMIUM_BINARY",
        "GOOGLE_CHROME_BINARY"
      ],
      "description": "Path to Chromium binary"
    },
    "MODALCLOSER_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "CLOSE_MODALS",
        "AUTO_CLOSE_MODALS"
      ],
      "description": "Enable automatic modal and dialog closing"
    },
    "MODALCLOSER_TIMEOUT": {
      "type": "integer",
      "default": 1250,
      "minimum": 100,
      "description": "Delay before auto-closing dialogs (ms)"
    },
    "MODALCLOSER_POLL_INTERVAL": {
      "type": "integer",
      "default": 500,
      "minimum": 100,
      "description": "How often to check for CSS modals (ms)"
    }
  }
}
