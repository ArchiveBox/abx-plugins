{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Puppeteer",
  "description": "Install and manage Chromium through the Puppeteer toolchain.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [
    {
      "name": "puppeteer",
      "binproviders": "npm",
      "min_version": null,
      "overrides": {
        "npm": {
          "install_args": [
            "puppeteer"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "x-aliases": [
        "CHROMIUM_BINARY",
        "GOOGLE_CHROME_BINARY"
      ],
      "description": "Path to Chromium binary"
    },
    "PUPPETEER_ENABLED": {
      "type": "boolean",
      "default": true,
      "description": "Enable Puppeteer dependency installation during crawl setup"
    },
    "PUPPETEER_CACHE_DIR": {
      "type": "string",
      "default": "",
      "description": "Override the Puppeteer browser cache directory"
    }
  }
}
