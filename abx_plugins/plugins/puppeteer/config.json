{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Puppeteer",
  "description": "Install and manage Google Chrome through the Puppeteer toolchain.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [
    {
      "name": "puppeteer",
      "binproviders": "npm",
      "min_version": null,
      "overrides": {
        "npm": {
          "install_args": [
            "puppeteer",
            "@puppeteer/browsers",
            "abxbus@^2.5.4",
            "--min-release-age=0"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chrome",
      "x-aliases": [
        "CHROMIUM_BINARY",
        "GOOGLE_CHROME_BINARY"
      ],
      "description": "Path to Chrome binary"
    },
    "PUPPETEER_ENABLED": {
      "type": "boolean",
      "default": true,
      "description": "Enable Puppeteer dependency installation during crawl setup"
    }
  }
}
