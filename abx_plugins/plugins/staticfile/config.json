{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Static File",
  "description": "Detect and download static-file responses directly when a URL resolves to a non-HTML asset.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    "chrome"
  ],
  "output_mimetypes": [
    "application/pdf",
    "application/epub+zip",
    "image/",
    "audio/",
    "video/",
    "application/json",
    "application/xml",
    "text/csv",
    "text/xml",
    "application/zip",
    "application/octet-stream",
    "application/x-"
  ],
  "properties": {
    "STATICFILE_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_STATICFILE",
        "USE_STATICFILE"
      ],
      "description": "Enable static file detection"
    },
    "STATICFILE_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for static file detection in seconds"
    }
  }
}
