{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Static File",
  "description": "Download static-file responses when a URL resolves to a non-HTML asset (e.g. direct PDF, image, mp4, etc. URLs).",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer,playwright",
      "min_version": "149.0.0",
      "postinstall_scripts": true
    }
  ],
  "output_mimetypes": [
    "application/pdf",
    "application/epub+zip",
    "image/",
    "audio/",
    "video/",
    "application/json",
    "application/xml",
    "text/csv",
    "text/xml",
    "application/zip",
    "application/octet-stream",
    "application/x-"
  ],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "description": "Path to a Chromium-family browser binary"
    },
    "STATICFILE_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_STATICFILE",
        "USE_STATICFILE"
      ],
      "description": "Enable static file detection"
    },
    "STATICFILE_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for static file detection in seconds"
    }
  }
}
