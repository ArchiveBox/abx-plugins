{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SSL Certificates",
  "description": "Capture TLS certificate and connection metadata for the loaded page.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": ["chrome"],
  "required_binaries": ["chrome"],
  "output_mimetypes": ["application/x-ndjson"],
  "properties": {
    "SSLCERTS_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": ["SAVE_SSLCERTS", "USE_SSLCERTS"],
      "description": "Enable SSL certificate capture"
    },
    "SSLCERTS_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for SSL capture in seconds"
    }
  }
}
