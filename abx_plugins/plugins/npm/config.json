{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "npm",
  "description": "Install binaries from npm packages and expose Node module paths.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [
    {
      "name": "{NODE_BINARY}",
      "binproviders": "env,apt,brew",
      "min_version": null,
      "overrides": {
        "apt": {
          "install_args": [
            "nodejs"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [],
  "properties": {
    "NODE_BINARY": {
      "type": "string",
      "default": "node",
      "description": "Path to Node.js binary"
    },
    "NPM_BINARY": {
      "type": "string",
      "default": "npm",
      "description": "Path to npm binary"
    }
  }
}
