{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Console Log",
  "description": "Capture browser console messages emitted while the page loads.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer",
      "min_version": null,
      "overrides": {
        "puppeteer": {
          "install_args": [
            "chrome@stable"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [
    "application/x-ndjson"
  ],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "x-aliases": [
        "CHROMIUM_BINARY"
      ],
      "description": "Path to Chromium, Chrome for Testing, or Chrome Canary binary"
    },
    "CONSOLELOG_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_CONSOLELOG",
        "USE_CONSOLELOG"
      ],
      "description": "Enable console log capture"
    },
    "CONSOLELOG_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for console log capture in seconds"
    }
  }
}
