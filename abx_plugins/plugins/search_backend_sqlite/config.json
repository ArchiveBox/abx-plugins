{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SQLite Search",
  "description": "Index archived snapshot content into a SQLite FTS database for local search.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [],
  "required_binaries": [],
  "output_mimetypes": [
    "application/vnd.sqlite3"
  ],
  "properties": {
    "SEARCH_BACKEND_ENGINE": {
      "type": "string",
      "default": "sqlite",
      "description": "Selected search backend implementation"
    },
    "USE_INDEXING_BACKEND": {
      "type": "boolean",
      "default": true,
      "description": "Enable search indexing for archived snapshots"
    },
    "SEARCH_BACKEND_SQLITE_DB": {
      "type": "string",
      "default": "search.sqlite3",
      "x-aliases": [
        "SQLITEFTS_DB"
      ],
      "description": "SQLite FTS database filename"
    },
    "SEARCH_BACKEND_SQLITE_SEPARATE_DATABASE": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "FTS_SEPARATE_DATABASE",
        "SQLITEFTS_SEPARATE_DATABASE"
      ],
      "description": "Use separate database file for FTS index"
    },
    "SEARCH_BACKEND_SQLITE_TOKENIZERS": {
      "type": "string",
      "default": "porter unicode61 remove_diacritics 2",
      "x-aliases": [
        "FTS_TOKENIZERS",
        "SQLITEFTS_TOKENIZERS"
      ],
      "description": "FTS5 tokenizer configuration"
    }
  }
}
