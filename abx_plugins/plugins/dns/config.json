{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DNS",
  "description": "Record DNS activity observed while loading the page in Chrome.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer",
      "min_version": null,
      "overrides": {
        "puppeteer": {
          "install_args": [
            "chrome@stable"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [
    "application/x-ndjson"
  ],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "description": "Path to a Chromium-family browser binary"
    },
    "DNS_ENABLED": {
      "type": "boolean",
      "default": true,
      "x-aliases": [
        "SAVE_DNS",
        "USE_DNS"
      ],
      "description": "Enable DNS traffic recording during page load"
    },
    "DNS_TIMEOUT": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "x-fallback": "TIMEOUT",
      "description": "Timeout for DNS recording in seconds"
    }
  }
}
