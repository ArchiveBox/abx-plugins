{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chrome Screencast",
  "description": "Stream low-resolution Chrome screencast JPEG frames for the admin live progress UI.",
  "type": "object",
  "additionalProperties": false,
  "required_plugins": [
    "chrome"
  ],
  "required_binaries": [
    {
      "name": "{CHROME_BINARY}",
      "binproviders": "env,puppeteer",
      "min_version": null,
      "overrides": {
        "puppeteer": {
          "install_args": [
            "chrome@stable"
          ]
        }
      }
    }
  ],
  "output_mimetypes": [
    "image/jpeg"
  ],
  "properties": {
    "CHROME_BINARY": {
      "type": "string",
      "default": "chromium",
      "description": "Path to a Chromium-family browser binary"
    },
    "CHROME_SCREENCAST_ENABLED": {
      "type": "boolean",
      "default": true,
      "description": "Enable live browser preview frames for the admin live progress UI"
    },
    "CHROME_SCREENCAST_WIDTH": {
      "type": "integer",
      "default": 320,
      "minimum": 64,
      "description": "Maximum screencast JPEG width"
    },
    "CHROME_SCREENCAST_HEIGHT": {
      "type": "integer",
      "default": 180,
      "minimum": 64,
      "description": "Maximum screencast JPEG height"
    },
    "CHROME_SCREENCAST_QUALITY": {
      "type": "integer",
      "default": 35,
      "minimum": 1,
      "maximum": 100,
      "description": "Live preview JPEG quality"
    },
    "CHROME_SCREENCAST_FPS": {
      "type": "integer",
      "default": 1,
      "minimum": 1,
      "maximum": 5,
      "description": "Maximum screencast JPEG frames written per second"
    },
    "CHROME_SCREENCAST_BUFFER": {
      "type": "integer",
      "default": 20,
      "minimum": 1,
      "maximum": 120,
      "description": "Number of recent screencast frames to keep in the rolling cache"
    }
  }
}
