        <div class="footer-meta">
          <span>Generated from <a href="{{ site.github_repo }}" target="_blank" rel="noreferrer">ArchiveBox/abx-plugins</a> at ref <code>{{ site.github_ref }}</code>.</span>
          <span>Updated {{ site.generated_at }}</span>
        </div>
