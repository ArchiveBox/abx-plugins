    <dialog class="plugin-modal" id="plugin-modal">
      <div class="plugin-modal-header">
        <div class="plugin-modal-header-left">
          <div class="plugin-icon" id="plugin-modal-icon"></div>
          <h2 id="plugin-modal-title"></h2>
        </div>
        <button type="button" class="plugin-modal-close" id="plugin-modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="plugin-body" id="plugin-modal-body"></div>
    </dialog>

    <script>
      const searchInput = document.getElementById("plugin-search");
      const cards = Array.from(document.querySelectorAll(".plugin-card"));
      const visibleCount = document.getElementById("visible-count");
      const emptyState = document.getElementById("empty-state");
      const selectedPluginName = document.getElementById("selected-plugin-name");
      const heroCommandExample = document.getElementById("hero-command-example");
      const copyExampleButton = document.getElementById("copy-example-button");
      const interactiveSelector = "a, button, input, textarea, select, summary, code, pre";
      let selectedCard = null;
      const accumulatedPlugins = [];
      let copyFeedbackTimer = null;

      const escapeHtml = (value) =>
        value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

      const highlightShell = (line) => {
        const tokenPattern = /('[^']*'|"[^"]*"|--[\w-]+(?:=[^\s'"]+)?|\b(?:uvx|abx-dl|archivebox)\b|\b[A-Z0-9_]+(?==)|\b(?:true|false)\b)/g;
        let html = "";
        let lastIndex = 0;

        for (const match of line.matchAll(tokenPattern)) {
          const token = match[0];
          const index = match.index ?? 0;
          html += escapeHtml(line.slice(lastIndex, index));

          let className = "code-value";
          if (token.startsWith("'") || token.startsWith('"')) {
            className = "code-string";
          } else if (token.startsWith("--")) {
            className = "code-option";
          } else if (token === "uvx" || token === "abx-dl" || token === "archivebox") {
            className = "code-command";
          } else if (token === "true" || token === "false") {
            className = "code-boolean";
          } else if (/^[A-Z0-9_]+$/.test(token)) {
            className = "code-env";
          }

          html += `<span class="${className}">${escapeHtml(token)}</span>`;
          lastIndex = index + token.length;
        }

        html += escapeHtml(line.slice(lastIndex));
        return html;
      };

      const getHeroExample = (card) => {
        if (!card) return null;

        const plugin = card.dataset.heroPlugin || card.id || "plugin";
        if (!accumulatedPlugins.includes(plugin)) {
          accumulatedPlugins.push(plugin);
        }

        const pluginsFlag = accumulatedPlugins.length
          ? ` --plugins=${accumulatedPlugins.join(",")}`
          : "";

        return {
          plugin: accumulatedPlugins.length ? plugin : "abx-dl",
          abx: `uvx abx-dl${pluginsFlag} 'https://example.com'`,
          archivebox: card.dataset.heroArchiveboxCommand || "archivebox add 'https://example.com'",
        };
      };

      const renderHeroExample = (example) => {
        const lines = [
          '<span class="code-comment"># run inside a new empty dir somewhere:</span>',
          highlightShell(example.abx),
          "",
          '<span class="code-comment"># or with ArchiveBox:</span>',
          highlightShell(example.archivebox),
        ];
        return lines.join("\n");
      };

      const heroExampleText = (example) =>
        ["# abx-dl", example.abx, "", "# ArchiveBox", example.archivebox].join("\n");

      const setHeroExample = (card) => {
        const example = getHeroExample(card);
        if (!example) return;

        selectedCard = card;
        selectedPluginName.textContent = example.plugin;
        heroCommandExample.innerHTML = renderHeroExample(example);
        copyExampleButton.dataset.copyText = heroExampleText(example);
      };

      const defaultHeroExample = {
        plugin: "abx-dl",
        abx: "uvx abx-dl 'https://example.com'",
        archivebox: "archivebox add 'https://example.com'",
      };

      const syncHeroExample = () => {
        if (selectedCard) {
          setHeroExample(selectedCard);
          return;
        }

        if (accumulatedPlugins.length === 0) {
          selectedPluginName.textContent = defaultHeroExample.plugin;
          heroCommandExample.innerHTML = renderHeroExample(defaultHeroExample);
          copyExampleButton.dataset.copyText = heroExampleText(defaultHeroExample);
          return;
        }

        const fallback = cards.find((card) => card.open && !card.hidden) || cards.find((card) => !card.hidden) || cards[0];
        if (fallback) {
          setHeroExample(fallback);
        }
      };

      const applyFilter = () => {
        const query = searchInput.value.trim().toLowerCase();
        let count = 0;

        for (const card of cards) {
          const matches = !query || card.dataset.search.includes(query);
          card.hidden = !matches;
          if (matches) count += 1;
        }

        visibleCount.textContent = String(count);
        emptyState.hidden = count !== 0;
      };

      const setHash = (value) => {
        const clean = value.replace(/^#/, "").trim();
        if (clean) {
          history.replaceState(null, "", "#" + clean);
        } else {
          history.replaceState(null, "", location.pathname + location.search);
        }
      };

      const navigateToHash = () => {
        const hash = decodeURIComponent(location.hash.replace(/^#/, "")).trim();
        if (!hash) return;

        const target = document.getElementById(hash);
        if (target && target.classList.contains("plugin-card")) {
          searchInput.value = "";
          applyFilter();
          openModal(target);
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        } else {
          searchInput.value = hash;
          applyFilter();
          searchInput.focus();
        }
      };

      const setCopyButtonLabel = (label) => {
        copyExampleButton.textContent = label;
        if (copyFeedbackTimer) {
          clearTimeout(copyFeedbackTimer);
        }
        copyFeedbackTimer = window.setTimeout(() => {
          copyExampleButton.textContent = "Copy";
        }, 1600);
      };

      const copyText = async (text) => {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "absolute";
        textarea.style.left = "-9999px";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      };

      searchInput.addEventListener("input", () => {
        applyFilter();
        syncHeroExample();
        setHash(searchInput.value.trim());
      });

      copyExampleButton.addEventListener("click", async () => {
        try {
          await copyText(copyExampleButton.dataset.copyText || "");
          setCopyButtonLabel("Copied");
        } catch (error) {
          setCopyButtonLabel("Copy failed");
        }
      });

      const modalEl = document.getElementById("plugin-modal");
      const modalTitle = document.getElementById("plugin-modal-title");
      const modalBody = document.getElementById("plugin-modal-body");
      const modalClose = document.getElementById("plugin-modal-close");
      const modalIcon = document.getElementById("plugin-modal-icon");
      let activeModalCard = null;

      // Tab switching for run-tabs
      const initRunTabs = (container) => {
        const tabs = container.querySelectorAll("[data-run-tab]");
        const panels = container.querySelectorAll("[data-run-panel]");
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const target = tab.dataset.runTab;
            tabs.forEach((t) => t.classList.toggle("active", t.dataset.runTab === target));
            panels.forEach((p) => p.classList.toggle("active", p.dataset.runPanel === target));
          });
        });
      };

      // Syntax highlight all [data-highlight-shell] elements
      const highlightAllShell = (root) => {
        root.querySelectorAll("[data-highlight-shell]").forEach((el) => {
          el.innerHTML = el.textContent.split("\n").map((line) => highlightShell(line)).join("\n");
        });
      };

      const openModal = (card) => {
        const body = card.querySelector(".plugin-body");
        const title = card.querySelector("h2");
        const icon = card.querySelector(".plugin-icon");
        if (!body) return;

        if (activeModalCard) activeModalCard.classList.remove("modal-active");
        activeModalCard = card;
        card.classList.add("modal-active");

        modalTitle.textContent = title ? title.textContent : card.id;
        modalIcon.innerHTML = icon ? icon.innerHTML : "";
        modalBody.innerHTML = body.innerHTML;
        modalBody.querySelectorAll("[data-run-tabs]").forEach(initRunTabs);
        highlightAllShell(modalBody);
        modalEl.showModal();

        setHash(card.id);
        setHeroExample(card);
      };

      const closeModal = () => {
        modalEl.close();
        if (activeModalCard) {
          activeModalCard.classList.remove("modal-active");
          activeModalCard = null;
        }
      };

      modalClose.addEventListener("click", closeModal);
      // Close on backdrop click (click on <dialog> itself, not its children)
      modalEl.addEventListener("click", (event) => {
        if (event.target === modalEl) closeModal();
      });
      modalBody.addEventListener("click", (event) => {
        const link = event.target.closest("a[href^='#']");
        if (!link) return;
        const id = link.getAttribute("href").slice(1);
        const target = document.getElementById(id);
        if (target && target.classList.contains("plugin-card")) {
          event.preventDefault();
          closeModal();
          openModal(target);
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });

      for (const card of cards) {
        const summary = card.querySelector("summary");
        if (summary) {
          summary.addEventListener("click", (event) => {
            event.preventDefault();
            if (event.target.closest("a, button, input, textarea, select")) return;
            openModal(card);
          });
        }
      }

      highlightAllShell(document);
      applyFilter();
      navigateToHash();
      syncHeroExample();
      window.addEventListener("hashchange", navigateToHash);
    </script>
  </body>
</html>
