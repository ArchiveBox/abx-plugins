    </div>

    <script>
      const searchInput = document.getElementById("plugin-search");
      const cards = Array.from(document.querySelectorAll(".plugin-card"));
      const visibleCount = document.getElementById("visible-count");
      const emptyState = document.getElementById("empty-state");
      const selectedPluginName = document.getElementById("selected-plugin-name");
      const heroCommandExample = document.getElementById("hero-command-example");
      const copyExampleButton = document.getElementById("copy-example-button");
      const interactiveSelector = "a, button, input, textarea, select, summary, code, pre";
      let selectedCard = null;
      const accumulatedPlugins = [];
      let copyFeedbackTimer = null;

      const escapeHtml = (value) =>
        value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

      const highlightShell = (line) => {
        const tokenPattern = /('[^']*'|"[^"]*"|--[\w-]+(?:=[^\s'"]+)?|\b(?:uvx|abx-dl|archivebox)\b|\b[A-Z0-9_]+(?==)|\b(?:true|false)\b)/g;
        let html = "";
        let lastIndex = 0;

        for (const match of line.matchAll(tokenPattern)) {
          const token = match[0];
          const index = match.index ?? 0;
          html += escapeHtml(line.slice(lastIndex, index));

          let className = "code-value";
          if (token.startsWith("'") || token.startsWith('"')) {
            className = "code-string";
          } else if (token.startsWith("--")) {
            className = "code-option";
          } else if (token === "uvx" || token === "abx-dl" || token === "archivebox") {
            className = "code-command";
          } else if (token === "true" || token === "false") {
            className = "code-boolean";
          } else if (/^[A-Z0-9_]+$/.test(token)) {
            className = "code-env";
          }

          html += `<span class="${className}">${escapeHtml(token)}</span>`;
          lastIndex = index + token.length;
        }

        html += escapeHtml(line.slice(lastIndex));
        return html;
      };

      const getHeroExample = (card) => {
        if (!card) return null;

        const plugin = card.dataset.heroPlugin || card.id || "plugin";
        if (!accumulatedPlugins.includes(plugin)) {
          accumulatedPlugins.push(plugin);
        }

        return {
          plugin,
          abx: `uvx abx-dl --plugins=${accumulatedPlugins.join(",")} 'https://example.com'`,
          archivebox: card.dataset.heroArchiveboxCommand || "archivebox add 'https://example.com'",
        };
      };

      const renderHeroExample = (example) => {
        const lines = [
          '<span class="code-comment"># run inside a new empty dir somewhere:</span>',
          highlightShell(example.abx),
          "",
          '<span class="code-comment"># or with ArchiveBox:</span>',
          highlightShell(example.archivebox),
        ];
        return lines.join("\n");
      };

      const heroExampleText = (example) =>
        ["# abx-dl", example.abx, "", "# ArchiveBox", example.archivebox].join("\n");

      const setHeroExample = (card) => {
        const example = getHeroExample(card);
        if (!example) return;

        selectedCard = card;
        selectedPluginName.textContent = example.plugin;
        heroCommandExample.innerHTML = renderHeroExample(example);
        copyExampleButton.dataset.copyText = heroExampleText(example);
      };

      const syncHeroExample = () => {
        if (selectedCard) {
          setHeroExample(selectedCard);
          return;
        }

        const fallback = cards.find((card) => card.open && !card.hidden) || cards.find((card) => !card.hidden) || cards[0];
        if (fallback) {
          setHeroExample(fallback);
        }
      };

      const applyFilter = () => {
        const query = searchInput.value.trim().toLowerCase();
        let count = 0;

        for (const card of cards) {
          const matches = !query || card.dataset.search.includes(query);
          card.hidden = !matches;
          if (matches) count += 1;
        }

        visibleCount.textContent = String(count);
        emptyState.hidden = count !== 0;
      };

      const setHash = (value) => {
        const clean = value.replace(/^#/, "").trim();
        if (clean) {
          history.replaceState(null, "", "#" + clean);
        } else {
          history.replaceState(null, "", location.pathname + location.search);
        }
      };

      const navigateToHash = () => {
        const hash = decodeURIComponent(location.hash.replace(/^#/, "")).trim();
        if (!hash) return;

        const target = document.getElementById(hash);
        if (target && target.classList.contains("plugin-card")) {
          searchInput.value = "";
          applyFilter();
          target.open = true;
          setHeroExample(target);
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        } else {
          searchInput.value = hash;
          applyFilter();
          searchInput.focus();
        }
      };

      const setCopyButtonLabel = (label) => {
        copyExampleButton.textContent = label;
        if (copyFeedbackTimer) {
          clearTimeout(copyFeedbackTimer);
        }
        copyFeedbackTimer = window.setTimeout(() => {
          copyExampleButton.textContent = "Copy";
        }, 1600);
      };

      const copyText = async (text) => {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "absolute";
        textarea.style.left = "-9999px";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      };

      searchInput.addEventListener("input", () => {
        applyFilter();
        syncHeroExample();
        setHash(searchInput.value.trim());
      });

      copyExampleButton.addEventListener("click", async () => {
        try {
          await copyText(copyExampleButton.dataset.copyText || "");
          setCopyButtonLabel("Copied");
        } catch (error) {
          setCopyButtonLabel("Copy failed");
        }
      });

      for (const card of cards) {
        card.addEventListener("click", (event) => {
          if (card.open) return;
          if (event.target.closest(interactiveSelector)) return;
          card.open = true;
        });

        card.addEventListener("toggle", () => {
          if (card.open) {
            setHash(card.id);
            setHeroExample(card);
          }
        });
      }

      applyFilter();
      navigateToHash();
      syncHeroExample();
      window.addEventListener("hashchange", navigateToHash);
    </script>
  </body>
</html>
