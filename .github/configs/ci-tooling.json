{
  "properties": {
    "NODE_BINARY": {
      "default": "node"
    },
    "PRETTIER_BINARY": {
      "default": "prettier"
    },
    "GH_BINARY": {
      "default": "gh"
    },
    "GIT_BINARY": {
      "default": "git"
    },
    "CURL_BINARY": {
      "default": "curl"
    },
    "JQ_BINARY": {
      "default": "jq"
    },
    "UV_BINARY": {
      "default": "uv"
    }
  },
  "node_binaries": [
    {
      "name": "{NODE_BINARY}",
      "binproviders": "env,npm",
      "min_version": "22.23.1",
      "overrides": {
        "npm": {
          "install_args": [
            "node@22.23.1"
          ],
          "postinstall_scripts": true
        }
      }
    }
  ],
  "prek_binaries": [
    {
      "name": "{NODE_BINARY}",
      "binproviders": "env,npm",
      "min_version": "22.23.1",
      "overrides": {
        "npm": {
          "install_args": [
            "node@22.23.1"
          ],
          "postinstall_scripts": true
        }
      }
    },
    {
      "name": "{PRETTIER_BINARY}",
      "binproviders": "env,npm",
      "min_version": "3.9.5",
      "overrides": {
        "npm": {
          "install_args": [
            "prettier@3.9.5"
          ],
          "postinstall_scripts": true
        }
      }
    }
  ],
  "release_binaries": [
    {
      "name": "{GH_BINARY}",
      "binproviders": "env,brew,apt"
    },
    {
      "name": "{GIT_BINARY}",
      "binproviders": "env,brew,apt"
    },
    {
      "name": "{CURL_BINARY}",
      "binproviders": "env,brew,apt"
    },
    {
      "name": "{JQ_BINARY}",
      "binproviders": "env,brew,apt"
    },
    {
      "name": "{UV_BINARY}",
      "binproviders": "env,brew"
    }
  ]
}
