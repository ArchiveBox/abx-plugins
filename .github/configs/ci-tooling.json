{
  "properties": {
    "NODE_BINARY": {
      "default": "node"
    },
    "PRETTIER_BINARY": {
      "default": "prettier"
    }
  },
  "node_binaries": [
    {
      "name": "{NODE_BINARY}",
      "binproviders": "env,npm",
      "min_version": "22.23.1",
      "overrides": {
        "npm": {
          "install_args": [
            "node@22.23.1"
          ],
          "postinstall_scripts": true
        }
      }
    }
  ],
  "prek_binaries": [
    {
      "name": "{NODE_BINARY}",
      "binproviders": "env,npm",
      "min_version": "22.23.1",
      "overrides": {
        "npm": {
          "install_args": [
            "node@22.23.1"
          ],
          "postinstall_scripts": true
        }
      }
    },
    {
      "name": "{PRETTIER_BINARY}",
      "binproviders": "env,npm",
      "min_version": "3.9.5",
      "overrides": {
        "npm": {
          "install_args": [
            "prettier@3.9.5"
          ],
          "postinstall_scripts": true
        }
      }
    }
  ]
}
